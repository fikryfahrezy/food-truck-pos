  },
  "dependencies": {
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.4.0",
    "clsx": "2.1.1",
    "nuxt": "4.3.0",
    "tailwind-merge": "3.5.0",
    "vue": "3.5.27",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/eslint": "1.13.0",
    "@nuxt/hints": "1.0.0-alpha.6",
    "@nuxt/test-utils": "3.23.0",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  }
