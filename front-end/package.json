{
  "name": "front-end",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "type-check": "tsc --noEmit",
