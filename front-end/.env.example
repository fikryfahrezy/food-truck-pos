# Dev with MSW (default): leave empty — requests stay same-origin, and the worker
# resolves them against the current browser URL before matching handlers.
NUXT_PUBLIC_API_BASE=
NUXT_PUBLIC_ENABLE_MSW=true

# Dev with real backend: point to the backend host and disable MSW.
# NUXT_PUBLIC_API_BASE=http://localhost:8080
# NUXT_PUBLIC_ENABLE_MSW=false

# Production:
# NUXT_PUBLIC_API_BASE=https://api.example.com
# NUXT_PUBLIC_ENABLE_MSW=false
